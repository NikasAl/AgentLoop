# AgentLoop — переменные окружения
# Скопируйте в .env и заполните ключи:  cp .env.example .env

# ─── API ключи (опционально) ──────────────────────────────
# OpenRouter — доступ к 100+ моделям
OPENROUTER_API_KEY=sk-or-v1-вставьте-ключ-сюда

# Z.AI — GLM модели (glm-4.7-flash бесплатно, glm-5-turbo и др.)
ZAI_API_KEY=вставьте-ключ-сюда

# ─── Локальная LLM ────────────────────────────────────────
# URL llama-server (по умолчанию http://turbo:8080)
LOCAL_LLM_URL=http://turbo:8080

# ─── Human-as-API ─────────────────────────────────────────
# Редактор для HumanProvider (по умолчанию subl)
EDITOR=subl
