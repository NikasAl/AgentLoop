  "_differences_from_extraction_dag": {
    "collection_outputs": "generate_poems_parallel возвращает 3 стиха как коллекцию, не один артефакт",
    "parallel_judges": "5 разных judge-узлов запускаются независимо",
    "human_judge_in_loop": "emotional_judge_human — LLM-узел с model=human:browser, не отдельный gate",
    "refine_vs_fix": "loop для refine (улучшение), не для fix (исправление ошибок)",
    "skip_human_in_loop": "re_evaluate пропускает emotional-метрику для скорости, она считается только в финале",
    "gate_with_modes": "final_human_review_gate имеет 4 режима (approve/reject/modify/accept_as_is), не 2",
    "multiple_schemas": "8 разных output_schema_ref, не 1 — каждый judge возвращает свой формат",
    "iterate_over_seeds": "вместо iterate_over коллекции, итерируемся по seed-ам для разнообразия"
  }
