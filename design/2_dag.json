      "{extract_problems.output.problems|length} >= 8 || {extract_problems.output.problems|length} == 0",
      "{run_tests.output.all_passed} == true"
    ],
    "operators": ["==", "!=", ">", ">=", "<", "<=", "&&", "||"],
    "filters": ["|length", "|is_empty", "|contains:'substring'"],
    "value_types": ["boolean", "integer", "string", "null"]
  }
}
