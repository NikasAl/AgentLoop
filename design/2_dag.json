      "script_path": "tools/custom/latex_validator_v1.py",
      "hitl_required_for": ["pip install (approved by user)"]
    }
  ],

  "input_vars_resolved_at_runtime": {
    "$INPUT": "path to PDF",
    "$PAGE_NUM": "page number to process",
    "$WORKDIR": "isolated working directory for this run",
    "$RUN_ID": "unique run identifier",
